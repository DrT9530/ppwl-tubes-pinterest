{
  "name": "ppwl-tubes-pinterest",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:fe": "bun --filter frontend dev",
    "dev:be": "bun --filter backend dev",
    "dev": "concurrently -n \"BE,FE\" -c \"yellow,cyan\" \"bun run dev:be\" \"bun run dev:fe\"",
    "db:migrate": "bun --filter backend prisma migrate dev",
    "db:studio": "bun --filter backend prisma studio",
    "db:generate": "bun --filter backend prisma generate",
    "build": "bun --filter frontend build"
  },
  "dependencies": {
    "date-fns": "^4.2.1"
  },
  "devDependencies": {
    "concurrently": "^10.0.0"
  }
}
